# Cloudflare R2 S3-compatible upload credentials.
# Copy to .env locally if you use a shell loader; do not commit real secrets.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=measured-space-tours
R2_PUBLIC_BASE_URL=https://tours.example.com

# Cloudflare Pages deployment secrets for CI.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT=measured-space-viewer
